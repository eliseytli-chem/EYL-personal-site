---
import { render } from 'astro:content';
import ArticleLayout from '../../layouts/ArticleLayout.astro';
import { getPublicEssays, getRoutableEssays, type Essay } from '../../lib/essays';

export async function getStaticPaths() {
  const essays = await getRoutableEssays();
  const listedEssays = await getPublicEssays();

  return essays.map((essay) => {
    const index = listedEssays.findIndex(({ id }) => id === essay.id);
    const previous = index > 0 ? listedEssays[index - 1] : undefined;
    const next = index >= 0 && index < listedEssays.length - 1 ? listedEssays[index + 1] : undefined;

    return { params: { slug: essay.id }, props: { essay, previous, next } };
  });
}

interface Props {
  essay: Essay;
  previous?: Essay;
  next?: Essay;
}

const { essay, previous, next } = Astro.props;
const { Content } = await render(essay);
---

<ArticleLayout article={essay} previous={previous} next={next}><Content /></ArticleLayout>
